# 开发环境（pnpm dev 自动加载）
# 敏感信息请放在 .env.development.local（已被 git 忽略）

# Privy — https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=cmpp4be6j00ro0bl26wmtix8c

# meme-server HTTP（本地后端）
# NEXT_PUBLIC_MEME_SERVER_BASE_URL=https://api-pre.leap.fun
NEXT_PUBLIC_MEME_SERVER_BASE_URL=http://localhost:8080

# account / world-cup 走线上（awsToken、leaderboard、graduation-race）
NEXT_PUBLIC_ACCOUNT_API_BASE_URL=https://api.leap.fun
NEXT_PUBLIC_WORLD_CUP_API_BASE_URL=https://api.leap.fun

# alt.fun 生产合约（HyperEVM）
# NEXT_PUBLIC_ZAP_ADDRESS=0x693f12e9e6b35b34458793546065e8b08e0299d6
# NEXT_PUBLIC_BONDING_ADDRESS=0xb68811BcC0e4FcD825aA49F9453b065ddF752FcB
