# HyperEVM 测试网（chain 998）
# 用法：部署合约后把下方 LEAP 地址换成脚本打印的值，再执行：
#   cp web/.env.testnet web/.env.development.local
# 然后重启 pnpm dev。钱包添加网络：chainId 998，RPC 见下方。

# Privy — https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=cmrao7ko400fc0dl3r3gr9qzw

# meme-server HTTP
NEXT_PUBLIC_MEME_SERVER_BASE_URL=http://localhost:8080
NEXT_PUBLIC_PROTOCOL_GRADUATION_USDC=1000
NEXT_PUBLIC_PROTOCOL_MIN_SEED_USDC=0
NEXT_PUBLIC_PROTOCOL_MAX_SEED_USDC=20
NEXT_PUBLIC_PROTOCOL_MIN_BUY_USDC=0.0001
NEXT_PUBLIC_PROTOCOL_SEED_PRESETS=0,5,10,20

# HyperEVM 测试网
NEXT_PUBLIC_EVM_CHAIN_ID=998
NEXT_PUBLIC_EVM_RPC_URL=https://rpc.hyperliquid-testnet.xyz/evm
NEXT_PUBLIC_EVM_EXPLORER_URL=https://testnet.purrsec.com

# ↓ 部署后从 contracts/deployments/hyperevm-testnet.json 或 forge 日志填入
NEXT_PUBLIC_ZAP_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_BONDING_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_ROUTER_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_USDC_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_CREATOR_REWARDS_ADDRESS=0x0000000000000000000000000000000000000000
