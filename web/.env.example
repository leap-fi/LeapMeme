# 环境文件说明：
# - .env.development     开发（pnpm dev）
# - .env.production      生产构建（pnpm build）
# - .env.*.local         本地私密覆盖（不提交，见 .gitignore）
#
# 从 https://dashboard.privy.io 获取 App ID
NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id_here

# meme-server HTTP（前端启动时 GET /market/protocol/config 拉取经济参数）
NEXT_PUBLIC_MEME_SERVER_BASE_URL=https://api-pre.leap.fun

# 协议经济参数 fallback（API 不可用时使用，须与后端/合约一致）
NEXT_PUBLIC_PROTOCOL_GRADUATION_USDC=1000
NEXT_PUBLIC_PROTOCOL_MIN_SEED_USDC=0
NEXT_PUBLIC_PROTOCOL_MAX_SEED_USDC=20
NEXT_PUBLIC_PROTOCOL_MIN_BUY_USDC=0.0001
NEXT_PUBLIC_PROTOCOL_MIN_SELL_USDC=0
NEXT_PUBLIC_PROTOCOL_SEED_PRESETS=0,5,10,20
NEXT_PUBLIC_PROTOCOL_BUY_FEE_BPS=75
NEXT_PUBLIC_PROTOCOL_SELL_FEE_BPS=75
NEXT_PUBLIC_PROTOCOL_CREATOR_FEE_SHARE_BPS=6667

# alt.fun 生产合约（HyperEVM）
NEXT_PUBLIC_ZAP_ADDRESS=0x693f12e9e6b35b34458793546065e8b08e0299d6
NEXT_PUBLIC_BONDING_ADDRESS=0xb68811BcC0e4FcD825aA49F9453b065ddF752FcB
NEXT_PUBLIC_ROUTER_ADDRESS=0x70c7eC6f85B960379b7ee60Af72E0f419d915878
NEXT_PUBLIC_USDC_ADDRESS=0xb88339CB7199b77E23DB6E890353E22632Ba630f
NEXT_PUBLIC_CREATOR_REWARDS_ADDRESS=0xb4894380282533A86cb241145fac54AaAc995F18

# Google Analytics 4（生产构建时加载；开发环境可不配置以免污染数据）
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-xxxxxxx

# Vercel Web Analytics：在 Vercel 控制台启用并重新部署后，构建会自动注入
# NEXT_PUBLIC_VERCEL_OBSERVABILITY_BASEPATH，无需手动配置
