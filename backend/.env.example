# Server
PORT=8080
GIN_MODE=debug

# MySQL（仓库根目录 docker compose up -d mysql redis）
MYSQL_DSN=root:password@tcp(127.0.0.1:13306)/leap_backend?charset=utf8mb4&parseTime=True&loc=Local

# 迁移目录（相对于 backend/ 工作目录）
MIGRATIONS_PATH=../database/migrations

# Redis (optional)
REDIS_CONN_STRING=redis://127.0.0.1:56379/0

# Security（框架预留）
SESSION_SECRET=change-me-to-a-random-string
JWT_SECRET=change-me-to-another-random-string
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_HOURS=168

# App
ENABLE_REGISTER=true
ENABLE_JOBS=true
SYNC_FREQUENCY=60

RUN_MIGRATIONS=true
AUTO_MIGRATE=false

CORS_ORIGINS=*

GLOBAL_API_RATE_LIMIT_ENABLE=true
GLOBAL_API_RATE_LIMIT=180
GLOBAL_API_RATE_LIMIT_DURATION=60

LOG_DIR=
LOG_LEVEL=debug
