# Server
PORT=8080
GIN_MODE=debug

# MySQL（仓库根目录 docker compose up -d mysql redis）
MYSQL_DSN=root:password@tcp(127.0.0.1:13306)/leap_backend?charset=utf8mb4&parseTime=True&loc=Local

# 迁移目录（相对于 backend/ 工作目录）
MIGRATIONS_PATH=../database/migrations

# Redis (optional)
REDIS_CONN_STRING=redis://127.0.0.1:56379/0

# Security（框架预留）
SESSION_SECRET=change-me-to-a-random-string
JWT_SECRET=change-me-to-another-random-string
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_HOURS=168

# App
ENABLE_REGISTER=true
ENABLE_JOBS=true
SYNC_FREQUENCY=60

RUN_MIGRATIONS=true
AUTO_MIGRATE=false

CORS_ORIGINS=*

GLOBAL_API_RATE_LIMIT_ENABLE=true
GLOBAL_API_RATE_LIMIT=180
GLOBAL_API_RATE_LIMIT_DURATION=60

LOG_DIR=
LOG_LEVEL=debug

# Chain indexer（HyperEVM）
INDEXER_ENABLED=false
CHAIN_RPC_URL=https://rpc.hyperliquid.xyz/evm
CHAIN_ID=999
ZAP_ADDRESS=0x5f66E5Ec4ec9F045E10a580e7bA1147b0c650E45
BONDING_ADDRESS=0x3d968edbed8c953C814FE7Ad207705525189D13A
ROUTER_ADDRESS=0xf1e943a1b78ac7F0976beC79c5F74C4B30C5646b
USDC_ADDRESS=0xb88339CB7199b77E23DB6E890353E22632Ba630f
# 回填历史时设置起始块；不设置则从启动时的最新块开始
# 把返回的十六进制转成十进制，再减 604800
# curl -s -X POST https://rpc.hyperliquid.xyz/evm \
#   -H "Content-Type: application/json" \
#   -d '{"jsonrpc":"2.0","method":"eth_blockNumber","params":[],"id":1}'
INDEXER_START_BLOCK=
INDEXER_BATCH_SIZE=50
INDEXER_CONFIRMATIONS=1
INDEXER_POLL_INTERVAL_SEC=3
