# HyperEVM 主网部署（DeployHyperEVM.s.sol）
# 复制为 .env.deploy 并填入 PRIVATE_KEY；勿提交 git。

# 必填：部署者私钥（hex，可带 0x 前缀）
PRIVATE_KEY=

# 可选：覆盖默认外链地址
USDC_ADDRESS=0xb88339CB7199b77E23DB6E890353E22632Ba630f
BOUNCE_GLOBAL_STORAGE=0xa07d06383c1863c8A54d427aC890643d76cc03ff
CHAIN_ID=999

# 可选：部署清单输出路径
DEPLOYMENTS_OUT=./deployments/hyperevm.json

# ── HyperEVM 测试网（chain 998）见 .env.deploy.testnet.example + DeployHyperEVMTestnet.s.sol ──
